---
import { ClientRouter, fade } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';

import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  noindex?: boolean;
}

const { title, description, image, type, publishedDate, noindex } = Astro.props;
const contentFade = fade({ duration: '0.18s' });
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
      noindex={noindex}
    />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-nav">Skip to main content</a>

    <header class="top-bar">
      <a href="/" class="brand">
        <img src="/icon.png" alt="" width="28" height="28" class="brand-icon" />
        <span class="brand-name">John Litzsinger</span>
      </a>
      <nav class="social-links" aria-label="Social links">
        <a href="mailto:jlitzsin@purdue.edu" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/johnlitzsinger" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://github.com/johnlitz" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
        <a href="https://reddit.com" target="_blank" rel="noopener noreferrer" aria-label="Reddit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
        </a>
        <a href="https://news.ycombinator.com" target="_blank" rel="noopener noreferrer" aria-label="Hacker News">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M0 24V0h24v24H0zM6.951 5.896l4.112 7.708v5.064h1.583v-4.972l4.148-7.799h-1.749l-2.457 4.875c-.372.745-.688 1.434-.688 1.434s-.297-.708-.651-1.434L8.831 5.896h-1.88z"/></svg>
        </a>
      </nav>
    </header>

    <main id="main-content" transition:animate={contentFade}>
      <slot />
    </main>
  </body>
</html>

<style>
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--content-max);
    margin-inline: auto;
    padding: var(--space-xl) var(--gutter) var(--space-lg);
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--foreground);
    font-weight: 600;
  }

  .brand:hover {
    text-decoration: none;
  }

  .brand-icon {
    border-radius: 4px;
  }

  .social-links {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .social-links a {
    color: var(--muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: color var(--duration-fast) ease;
  }

  .social-links a:hover {
    color: var(--foreground);
    text-decoration: none;
  }

  main {
    max-width: var(--content-max);
    margin-inline: auto;
    padding: 0 var(--gutter) var(--space-2xl);
  }

  @media (max-width: 768px) {
    .top-bar {
      padding: var(--space-lg) var(--gutter) var(--space-md);
    }

    .social-links {
      gap: var(--space-sm);
    }
  }

  @media (max-width: 480px) {
    .brand-name {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .social-links a {
      transition: none;
    }
  }
</style>
