---
import BaseHead from '../components/BaseHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
}

const { title, description, image, type, noindex } = Astro.props;
const pathname = Astro.url.pathname;
const isHome = pathname === '/';

const navItems = [
  { label: 'About', href: '/about' },
  { label: 'Work', href: '/work' },
  { label: 'Resume', href: '/resume' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
    />
  </head>
  <body class:list={[{ home: isHome }]}>
    <a href="#main-content" class="skip-nav">Skip to content</a>

    <div class="frame">
      {!isHome && (
        <header class="top-bar">
          <a href="/" class="mark">jl</a>
          <nav class="nav" aria-label="Main navigation">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={['nav-link', { active: isActive(item.href) }]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </header>
      )}

      <main id="main-content" class="main">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  /* ── Frame — bordered document wrapper ── */

  .frame {
    border: var(--frame-border);
    max-width: var(--content-max);
    width: 100%;
    margin: var(--space-lg) auto;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  /* ── Top bar (inner pages only) ── */

  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-md) var(--frame-pad);
    flex-shrink: 0;
    border-bottom: var(--frame-border);
  }

  .mark {
    font-weight: 700;
    font-size: var(--text-lg);
    color: var(--accent);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mark:hover {
    color: var(--accent-hover);
  }

  .nav {
    display: flex;
    gap: var(--space-lg);
  }

  .nav-link {
    color: var(--muted);
    text-decoration: none;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding-bottom: 2px;
    border-bottom: 2px solid transparent;
    transition: color var(--transition), border-color var(--transition);
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link.active {
    color: var(--text);
    font-weight: 500;
    border-bottom-color: var(--accent);
  }

  /* ── Main content ── */

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: var(--frame-pad-y) var(--frame-pad);
    overflow: hidden;
    min-height: 0;
  }

  /* ── Homepage: center content in full viewport ── */

  body.home .main {
    align-items: center;
    text-align: center;
    padding: var(--frame-pad);
    padding-bottom: 0;
  }

  /* ── Mobile ── */

  @media (max-width: 480px) {
    .frame {
      margin: var(--space-md) auto;
    }

    .nav {
      gap: var(--space-md);
    }

    .nav-link {
      font-size: var(--text-xs);
    }
  }
</style>
