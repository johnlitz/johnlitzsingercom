---
import { ClientRouter, fade } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';

import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
  noindex?: boolean;
  scrollable?: boolean;
  hideNavName?: boolean;
  breadcrumbs?: { label: string; href?: string }[];
}

import { currentStatus } from '../data/status';

const { title, description, image, type, publishedDate, noindex, scrollable, hideNavName, breadcrumbs } = Astro.props;
const contentFade = fade({ duration: '0.15s' });
const pathname = Astro.url.pathname;

// Derive section color and background from first breadcrumb label
const sectionColorMap: Record<string, { color: string; bg: string }> = {
  'Now': { color: 'var(--now-500)', bg: 'var(--now-50)' },
  'Work': { color: 'var(--work-500)', bg: 'var(--work-50)' },
  'Guest Book': { color: 'var(--guestbook-500)', bg: 'var(--guestbook-50)' },
  'About': { color: 'var(--about-500)', bg: 'var(--about-50)' },
};
const firstCrumb = breadcrumbs?.[0]?.label ?? '';
const section = sectionColorMap[firstCrumb];
const sectionColor = section?.color ?? 'var(--accent)';
const sectionBg = section?.bg ?? 'var(--background)';

// CSS filter to shift logo icon to match section color.
// hue-rotate shifts the icon's hue; brightness corrects for the
// luminance difference between dark red (#d80000) and each target color.
const sectionFilterMap: Record<string, string> = {
  'Now':        'hue-rotate(217deg) saturate(0.85) brightness(1.75)',
  'Work':       'hue-rotate(142deg) saturate(0.75) brightness(1.95)',
  'Guest Book': 'hue-rotate(38deg)  saturate(0.9)  brightness(1.65)',
  'About':      'hue-rotate(262deg) saturate(0.85) brightness(1.25)',
};
const iconFilter = sectionFilterMap[firstCrumb] ?? 'none';
---

<!doctype html>
<html lang="en" transition:animate="none" style={`--page-bg: ${sectionBg}; --section-color: ${sectionColor}; --icon-filter: ${iconFilter};`}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      type={type}
      publishedDate={publishedDate}
      noindex={noindex}
    />
    <ClientRouter />
  </head>
  <body class:list={['viewport-lock', { 'allow-scroll': scrollable }]}>
    <a href="#main-content" class="skip-nav">Skip to main content</a>

    <header class="top-bar">
      <a href="/" class="brand">
        <img src="/icon.png" alt="" width="36" height="36" class="brand-icon" />
        <span class:list={['brand-name', { 'hidden-on-home': hideNavName }]} style="font-family: var(--font-brand); font-weight: 700;">John Litzsinger</span>
      </a>
      <nav class="social-links" aria-label="Social links">
        <a href="mailto:jlitzsin@purdue.edu" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        </a>
        <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/johnlitzsinger" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://github.com/johnlitz" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        </a>
      </nav>
    </header>

    {breadcrumbs && breadcrumbs.length > 0 && (
      breadcrumbs.length === 1 && !breadcrumbs[0].href ? (
        <nav class="section-header" aria-label="Section">
          <a href="/" class="section-back" aria-label="Back to home">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5" />
              <path d="m12 19-7-7 7-7" />
            </svg>
          </a>
          <svg class="section-folder" viewBox="0 0 80 64" width="28" height="22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="0" y="14" width="80" height="50" rx="4" fill="var(--section-color)" />
            <path d="M0 6a4 4 0 0 1 4-4h22a4 4 0 0 1 3.2 1.6L34 10H0V6Z" fill="var(--section-color)" />
            <rect x="0" y="10" width="80" height="4" fill="var(--section-color)" opacity="0.85" />
          </svg>
          <h1 class="section-title">{breadcrumbs[0].label}</h1>
        </nav>
      ) : (
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/" class="back-arrow" aria-label="Back to home">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 12H5" />
              <path d="m12 19-7-7 7-7" />
            </svg>
          </a>
          <svg class="crumb-folder-icon" viewBox="0 0 80 64" width="16" height="13" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="0" y="14" width="80" height="50" rx="4" fill="var(--section-color)" />
            <path d="M0 6a4 4 0 0 1 4-4h22a4 4 0 0 1 3.2 1.6L34 10H0V6Z" fill="var(--section-color)" />
            <rect x="0" y="10" width="80" height="4" fill="var(--section-color)" opacity="0.85" />
          </svg>
          <a href="/" class="crumb">jl</a>
          {breadcrumbs.map((crumb) => (
            <>
              <span class="crumb-sep" aria-hidden="true">›</span>
              {crumb.href ? (
                <a href={crumb.href} class="crumb">{crumb.label}</a>
              ) : (
                <span class="crumb crumb-current">{crumb.label}</span>
              )}
            </>
          ))}
        </nav>
      )
    )}

    <main id="main-content" class="page-content" transition:animate={contentFade}>
      <slot />
    </main>

    <footer class="site-footer">
      <span>&copy; 2026 John Litzsinger</span>
      <span class="footer-status">
        <span class="footer-dot" aria-hidden="true"></span>
        Currently {currentStatus.label}:{' '}
        {currentStatus.projectUrl ? (
          <a href={currentStatus.projectUrl} class="footer-status-link">{currentStatus.project}</a>
        ) : (
          <span>{currentStatus.project}</span>
        )}
        {currentStatus.note && (
          <span class="footer-note"> · {currentStatus.note}</span>
        )}
      </span>
    </footer>
  </body>
</html>

<style>
  html {
    background-color: var(--page-bg, var(--background));
    transition: background-color var(--duration-fast) ease-in-out;
  }

  .viewport-lock {
    display: flex;
    flex-direction: column;
    height: 100dvh;
    overflow: hidden;
  }

  .viewport-lock.allow-scroll {
    height: auto;
    min-height: 100dvh;
    overflow-y: auto;
  }

  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--content-max);
    margin-inline: auto;
    width: 100%;
    padding: var(--space-md) var(--gutter) var(--space-sm);
    flex-shrink: 0;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--foreground);
    font-weight: 600;
  }

  .brand:hover {
    text-decoration: none;
  }

  .brand-icon {
    border-radius: 6px;
    width: 36px;
    height: 36px;
    filter: var(--icon-filter, none);
    transition: filter var(--duration-fast) ease-in-out;
  }

  .brand-name {
    position: relative;
  }

  .brand-name.hidden-on-home {
    visibility: hidden;
  }

  .brand-name::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 50%;
    right: 50%;
    height: 2px;
    background: var(--section-color, var(--accent));
    border-radius: 1px;
    transition: left 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                right 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .brand:hover .brand-name::after {
    left: 0;
    right: 0;
  }

  .social-links {
    display: flex;
    gap: var(--space-xs);
    align-items: center;
  }

  .social-links a {
    color: var(--muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    transition: color var(--duration-fast) ease;
  }

  .social-links a:hover {
    color: var(--section-color, var(--accent));
    text-decoration: none;
  }

  .breadcrumb {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--gutter);
    max-width: var(--content-max);
    margin-inline: auto;
    width: 100%;
    flex-shrink: 0;
    position: relative;
  }

  .back-arrow {
    position: absolute;
    left: var(--gutter);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    text-decoration: none;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    transition: color var(--duration-fast) ease,
                background-color var(--duration-fast) ease;
  }

  .back-arrow:hover {
    color: var(--section-color);
    background: color-mix(in srgb, var(--section-color) 8%, transparent);
    text-decoration: none;
  }

  .crumb-folder-icon {
    flex-shrink: 0;
    filter: drop-shadow(0 1px 3px color-mix(in srgb, var(--section-color) 30%, transparent));
  }

  .crumb {
    color: var(--muted);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .crumb:hover {
    color: var(--section-color);
    text-decoration: none;
  }

  .crumb-current {
    color: var(--section-color);
    font-weight: 600;
  }

  .crumb-sep {
    color: var(--muted);
    user-select: none;
    font-size: var(--text-xs);
    opacity: 0.6;
  }

  /* Section page header — breadcrumb as title */
  .section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--gutter);
    max-width: var(--content-max);
    margin-inline: auto;
    width: 100%;
    flex-shrink: 0;
    position: relative;
  }

  .section-back {
    position: absolute;
    left: var(--gutter);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    text-decoration: none;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    transition: color var(--duration-fast) ease,
                background-color var(--duration-fast) ease;
  }

  .section-back:hover {
    color: var(--section-color);
    background: color-mix(in srgb, var(--section-color) 8%, transparent);
    text-decoration: none;
  }

  .section-folder {
    flex-shrink: 0;
    filter: drop-shadow(0 1px 3px color-mix(in srgb, var(--section-color) 30%, transparent));
  }

  .section-title {
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
    color: var(--section-color);
    font-weight: 600;
    line-height: 1.1;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--content-max);
    margin-inline: auto;
    width: 100%;
    padding: var(--space-sm) var(--gutter);
    font-size: var(--text-xs);
    color: var(--muted);
    flex-shrink: 0;
  }

  .footer-status {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
  }

  .footer-status-link {
    color: var(--foreground);
    font-weight: 500;
    text-decoration: none;
    position: relative;
    transition: color var(--duration-fast) ease;
  }

  .footer-status-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 100%;
    height: 1px;
    background: var(--section-color, var(--accent));
    transition: right 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .footer-status-link:hover {
    color: var(--section-color, var(--accent));
    text-decoration: none;
  }

  .footer-status-link:hover::after {
    right: 0;
  }

  .footer-note {
    color: var(--muted);
    font-family: var(--font-mono);
  }

  .footer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--status-green);
    animation: status-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  main {
    flex: 1;
    min-height: 0;
    max-width: var(--content-max);
    margin-inline: auto;
    width: 100%;
    padding: var(--space-md) var(--gutter) 0;
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .top-bar {
      padding: var(--space-sm) var(--gutter) var(--space-xs);
    }

    .social-links {
      gap: 0;
    }
  }

  @media (max-width: 640px) {
    .viewport-lock {
      height: auto;
      min-height: 100dvh;
      overflow-y: auto;
    }
  }

  @media (max-width: 480px) {
    .brand-name {
      display: none;
    }

    .social-links a[aria-label="X"],
    .social-links a[aria-label="LinkedIn"] {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      transition: none;
    }
    .brand-icon,
    .brand-name::after,
    .social-links a,
    .crumb,
    .back-arrow,
    .section-back,
    .footer-status a {
      transition: none;
    }
    .footer-dot {
      animation: none;
    }
  }
</style>
