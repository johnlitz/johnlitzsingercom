---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found — John Litzsinger"
  description="The page you're looking for doesn't exist."
  breadcrumbs={[{ label: '404' }]}
>
  <div class="not-found">
    <svg viewBox="0 0 80 64" width="72" height="58" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="0" y="14" width="80" height="50" rx="4" fill="var(--accent)" />
      <path d="M0 6a4 4 0 0 1 4-4h22a4 4 0 0 1 3.2 1.6L34 10H0V6Z" fill="var(--accent)" />
      <rect x="0" y="10" width="80" height="4" fill="var(--accent)" opacity="0.85" />
    </svg>
    <h1>This folder is empty</h1>
    <p>The page you're looking for doesn't exist.</p>
    <a href="/" class="go-home">Go home</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    max-width: 400px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
  }

  h1 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--foreground);
  }

  p {
    color: var(--secondary);
  }

  .go-home {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .go-home:hover {
    text-decoration: underline;
    opacity: 0.8;
  }
</style>
