---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Not Found — John Litzsinger"
  description="Page not found."
  noindex
>
  <div class="not-found">
    <p>Page not found.</p>
    <a href="/">Go home &rarr;</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: 1;
    gap: var(--space-md);
    color: var(--muted);
  }

  .not-found a {
    font-size: var(--text-sm);
  }
</style>
