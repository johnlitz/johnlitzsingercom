---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — John Litzsinger"
  description="Finance @ Purdue. Building startups, tools, and this website."
  breadcrumbs={[{ label: 'About' }]}
  scrollable={true}
>
  <div class="about-page">
    <div class="about-body">
      <p class="bio">
        I'm John — I care about markets, startups, and what happens when technology meets money.
        Currently a finance student at Purdue, co-founder of Launch Consulting Club, and always building something.
      </p>

      <div class="about-visual">
        <img
          src="/images/calvin-hobbes-relax.gif"
          alt="Calvin and Hobbes relaxing under a tree"
          class="about-gif"
        />
        <p class="about-caption">taking it easy</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .about-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-md);
    padding-bottom: var(--space-xl);
  }

  .bio {
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--foreground);
    max-width: 46ch;
    text-align: center;
  }

  .about-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .about-gif {
    max-width: 280px;
    width: 100%;
    height: auto;
    border-radius: 12px;
    outline: 1px solid var(--border-subtle);
    outline-offset: -1px;
    box-shadow: var(--shadow-sm);
  }

  .about-caption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    font-style: italic;
  }

</style>
