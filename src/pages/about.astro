---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — John Litzsinger"
  description="Finance @ Purdue. Building startups, tools, and this website."
>
  <div class="about">
    <p class="bio">
      I'm John — I care about markets, startups, and what happens when
      technology meets money. Currently a finance student at Purdue, co-founder
      of Launch Consulting Club, and always building something.
    </p>

    <div class="visual">
      <img
        src="/images/calvin-hobbes-relax.gif"
        alt="Calvin and Hobbes relaxing under a tree"
        class="gif"
      />
      <p class="caption">taking it easy</p>
    </div>

    <div class="links">
      <a href="mailto:jlitzsin@purdue.edu">Email</a>
      <a href="https://github.com/johnlitz" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.linkedin.com/in/johnlitzsinger" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </div>
</BaseLayout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .bio {
    font-size: var(--text-lg);
    line-height: 1.7;
    max-width: 36em;
  }

  .visual {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .gif {
    max-width: 240px;
    border: 1px solid var(--border);
  }

  .caption {
    font-size: var(--text-xs);
    color: var(--muted);
    font-style: italic;
  }

  .links {
    display: flex;
    border-top: var(--frame-border);
    margin-left: calc(-1 * var(--frame-pad));
    margin-right: calc(-1 * var(--frame-pad));
    margin-bottom: calc(-1 * var(--frame-pad-y));
    width: calc(100% + 2 * var(--frame-pad));
  }

  .links a {
    flex: 1;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: var(--text-sm);
    padding: var(--space-md) var(--space-sm);
    color: var(--muted);
    transition: color var(--transition);
  }

  .links a + a {
    border-left: var(--frame-border);
  }

  .links a:hover {
    color: var(--accent);
  }
</style>
