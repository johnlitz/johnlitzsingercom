---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — John Litzsinger"
  description="Finance @ Purdue. Building startups, tools, and this website."
  breadcrumbs={[{ label: 'About' }]}
>
  <div class="about-page">
    <h1>About</h1>
    <div class="about-body">
      <p class="bio">
        I'm John — a finance student at Purdue interested in startups, markets, and building things.
        I co-founded Launch Consulting Club and spend my free time writing code and breaking spreadsheets.
      </p>

      <div class="about-visual">
        <img
          src="/images/calvin-hobbes-relax.gif"
          alt="Calvin and Hobbes relaxing under a tree"
          class="about-gif"
        />
        <p class="about-caption">taking it easy</p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .about-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    padding-top: var(--space-md);
  }

  h1 {
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
    color: var(--about-500);
    text-align: center;
  }

  .bio {
    font-size: var(--text-lg);
    line-height: 1.65;
    color: var(--foreground);
    max-width: 46ch;
    text-align: center;
  }

  .about-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .about-gif {
    max-width: 280px;
    width: 100%;
    height: auto;
    border-radius: 12px;
    outline: 1px solid oklch(0.50 0.00 0 / 0.08);
    outline-offset: -1px;
  }

  .about-caption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    font-style: italic;
  }
</style>
