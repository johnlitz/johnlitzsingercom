---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="bLitz Feed — John Litzsinger"
  description="Blog posts and writing."
  breadcrumbs={[{ label: 'Feed' }]}
>
  <div class="feed-page">
    <h1>bLitz Feed</h1>
    {posts.length === 0 ? (
      <p class="empty">No posts yet. More writing coming soon.</p>
    ) : (
      <div class="post-listing">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <span class="accent-dot" aria-hidden="true"></span>
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <span class="post-tags">{post.data.tags.join(' · ')}</span>
            )}
          </a>
        ))}
      </div>
    )}
    {posts.length > 0 && posts.length < 3 && (
      <p class="more-soon">More writing coming soon.</p>
    )}
  </div>
</BaseLayout>

<style>
  .feed-page {
    max-width: var(--content-max);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h1 {
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .post-listing {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    width: 100%;
    align-items: center;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    padding: var(--space-lg) var(--space-md);
    max-width: 480px;
    width: 100%;
    transition: transform var(--duration-base) cubic-bezier(0.22, 1, 0.36, 1);
  }

  .post-card:hover {
    transform: translateY(-2px);
    text-decoration: none;
  }

  .post-card:hover h3 {
    color: var(--accent);
  }

  .accent-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--folder-feed);
    margin-bottom: var(--space-md);
    transition: transform var(--duration-fast) ease;
  }

  .post-card:hover .accent-dot {
    transform: scale(1.5);
  }

  .post-card time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    display: block;
    margin-bottom: var(--space-sm);
  }

  .post-card h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: var(--space-xs);
    transition: color var(--duration-fast) ease;
  }

  .post-card p {
    font-size: var(--text-sm);
    color: var(--secondary);
    line-height: 1.5;
  }

  .post-tags {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    margin-top: var(--space-sm);
  }

  .empty, .more-soon {
    color: var(--muted);
    font-size: var(--text-sm);
    margin-top: var(--space-lg);
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card, .post-card h3, .accent-dot { transition: none; }
    .post-card:hover { transform: none; }
    .post-card:hover .accent-dot { transform: none; }
  }
</style>
