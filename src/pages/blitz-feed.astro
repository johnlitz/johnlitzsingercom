---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="bLitz Feed — John Litzsinger"
  description="Blog posts and curated social feed."
>
  <div class="blitz-feed">
    <h1>bLitz Feed</h1>
    <div class="feed-grid">
      <section class="blog-column">
        <h2>Writing</h2>
        {posts.length === 0 ? (
          <p class="empty">No posts yet.</p>
        ) : (
          <div class="posts">
            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="post-entry">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </a>
            ))}
          </div>
        )}
      </section>
      <section class="social-column">
        <h2>Social</h2>
        <p class="coming-soon">
          Aggregated feed from X, LinkedIn, Reddit, GitHub, and HN — coming soon.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .blitz-feed {
    max-width: var(--content-max);
  }

  h1 {
    font-size: var(--text-2xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xl);
  }

  .feed-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-xl);
  }

  h2 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .posts {
    display: flex;
    flex-direction: column;
  }

  .post-entry {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: var(--space-md) 0;
    border-top: 1px solid var(--border);
    transition: background-color var(--duration-fast) ease;
  }

  .post-entry:hover {
    text-decoration: none;
  }

  .post-entry:hover h3 {
    color: var(--accent);
  }

  .post-entry time {
    font-size: var(--text-xs);
    color: var(--muted);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .post-entry h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: var(--space-xs);
    transition: color var(--duration-fast) ease;
  }

  .post-entry p {
    font-size: var(--text-sm);
    color: var(--secondary);
    line-height: 1.5;
  }

  .empty {
    color: var(--muted);
  }

  .coming-soon {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.55;
    padding: var(--space-md);
    border: 1px dashed var(--border);
    border-radius: 4px;
  }

  @media (max-width: 600px) {
    .feed-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-entry,
    .post-entry h3 {
      transition: none;
    }
  }
</style>
