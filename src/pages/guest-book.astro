---
import BaseLayout from '../layouts/BaseLayout.astro';
import GuestBookPage from '../components/react/GuestBookPage';
---

<BaseLayout
  title="Guest Book — John Litzsinger"
  description="Leave a note. Say hi."
  breadcrumbs={[{ label: 'Guest Book' }]}
  scrollable
>
  <div class="guestbook-page">
    <GuestBookPage client:idle />
  </div>
</BaseLayout>

<style>
  .guestbook-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    flex: 1;
  }

</style>
