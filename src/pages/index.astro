---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../data/projects';
---

<BaseLayout
  title="John Litzsinger"
  description="Finance, markets, and technology."
>
  <div class="home">
    <p class="tagline">Finance @ Purdue interested in startups.</p>

    <nav class="folder-nav" aria-label="Browse">
      <a href="/work" class="folder">
        <svg class="folder-icon" width="20" height="16" viewBox="0 0 20 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
          <path d="M1 4h18v11H1z"/>
          <path d="M1 4l1.5-3h5L9 4"/>
        </svg>
        <span>Work</span>
      </a>
      <a href="/blitz-feed" class="folder">
        <svg class="folder-icon" width="20" height="16" viewBox="0 0 20 16" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round">
          <path d="M1 4h18v11H1z"/>
          <path d="M1 4l1.5-3h5L9 4"/>
        </svg>
        <span>bLitz Feed</span>
      </a>
    </nav>

    <section class="projects-section">
      <h2>Projects</h2>
      <div class="project-grid">
        {projects.map((p) => (
          <a href={`/work/${p.slug}`} class="project-card">
            <h3>{p.title}</h3>
            <p class="project-desc">{p.description}</p>
            <span class="project-tech">{p.tech.join(' / ')}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .tagline {
    font-size: var(--text-2xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--foreground);
    max-width: 20ch;
  }

  /* Folder navigation — Linux aesthetic */
  .folder-nav {
    display: flex;
    gap: var(--space-lg);
  }

  .folder {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--foreground);
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border-radius: 4px;
    transition: background-color var(--duration-fast) ease;
  }

  .folder:hover {
    background-color: var(--surface);
    text-decoration: none;
  }

  .folder-icon {
    flex-shrink: 0;
    color: var(--muted);
  }

  .folder:hover .folder-icon {
    color: var(--accent);
  }

  /* Project grid */
  .projects-section h2 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-md);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    border: 1px solid var(--border);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast) ease,
                background-color var(--duration-fast) ease;
  }

  .project-card:hover {
    border-color: var(--muted);
    background-color: var(--surface);
    text-decoration: none;
  }

  .project-card h3 {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--foreground);
  }

  .project-desc {
    font-size: var(--text-sm);
    color: var(--secondary);
    line-height: 1.5;
  }

  .project-tech {
    font-size: var(--text-xs);
    color: var(--muted);
    margin-top: auto;
  }

  @media (max-width: 600px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .folder-nav {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .folder,
    .project-card {
      transition: none;
    }
  }
</style>
