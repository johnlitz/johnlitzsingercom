---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="John Litzsinger"
  description="Finance @ Purdue. Markets, startups, and technology."
>
  <div class="title-page">
    <h1 class="name">John Litzsinger</h1>
    <p class="tagline">Finance @ Purdue. Markets, startups, and technology.</p>
    <nav class="home-nav" aria-label="Main navigation">
      <a href="/about">About</a>
      <a href="/work">Work</a>
      <a href="/resume">Resume</a>
    </nav>
  </div>
</BaseLayout>

<style>
  .title-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .name {
    font-size: var(--text-4xl);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .tagline {
    font-size: var(--text-lg);
    color: var(--muted);
    max-width: 28em;
  }

  .home-nav {
    display: flex;
    gap: var(--space-xl);
    margin-top: var(--space-sm);
  }

  .home-nav a {
    color: var(--muted);
    font-size: var(--text-base);
    text-decoration: none;
    transition: color var(--transition);
  }

  .home-nav a:hover {
    color: var(--text);
  }
</style>
