---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const lastUpdated = posts[0]?.data.pubDate ?? new Date();
---

<BaseLayout
  title="Now — John Litzsinger"
  description="What I'm up to right now."
  breadcrumbs={[{ label: 'Now' }]}
>
  <div class="now-page">
    <header class="now-header">
      <time class="last-updated" datetime={lastUpdated.toISOString()}>
        Last updated {lastUpdated.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        })}
      </time>
    </header>

    {posts.length === 0 ? (
      <p class="empty">No entries yet.</p>
    ) : (
      <ul class="entry-list">
        {posts.map((post) => (
          <li class="entry-row-item">
            <a href={`/blog/${post.id}`} class="entry-row">
              <span class="entry-title">{post.data.title}</span>
              <time
                datetime={post.data.pubDate.toISOString()}
                class="entry-date"
              >
                {post.data.pubDate.toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>

<style>
  .now-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }

  .now-header {
    text-align: center;
    margin-bottom: var(--space-md);
  }

  .last-updated {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .entry-list {
    list-style: none;
    width: 100%;
    max-width: 480px;
    margin-top: var(--space-md);
    padding: 0;
  }

  .entry-row-item:not(:last-child) .entry-row {
    border-bottom: 1px solid var(--border-subtle);
  }

  .entry-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-lg);
    padding: var(--space-3) 0;
    text-decoration: none;
    color: inherit;
    transition: color var(--duration-fast) ease;
  }

  .entry-row:hover .entry-title {
    color: var(--now-500);
  }

  .entry-title {
    flex: 1;
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--foreground);
    transition: color var(--duration-fast) ease;
  }

  .entry-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .empty {
    color: var(--muted);
    font-size: var(--text-sm);
    text-align: center;
    margin-top: var(--space-md);
  }

  @media (prefers-reduced-motion: reduce) {
    .entry-row,
    .entry-title {
      transition: none;
    }
  }
</style>
